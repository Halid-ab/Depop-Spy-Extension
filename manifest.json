{
  "manifest_version": 3,
  "name": "Depop Price Spy",
  "version": "1.0",
  "description": "Track price drops and see average sold prices on Depop listings.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.depop.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://www.depop.com/*",
        "*://depop.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    },
    {
      "matches": [
        "*://www.depop.com/*",
        "*://depop.com/*"
      ],
      "js": [
        "inject.js"
      ],
      "world": "MAIN",
      "run_at": "document_start"
    }
  ]
}
